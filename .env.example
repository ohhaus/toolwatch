# Development-only values. Replace them outside local development.
APP_NAME=ToolWatch
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://toolwatch:toolwatch@localhost:5432/toolwatch
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_CONNECT_TIMEOUT_SECONDS=5
STORE_PROMPTS=false
DEFAULT_TOOL_TIMEOUT_SECONDS=10
MAX_TOOL_TIMEOUT_SECONDS=30
MAX_TOOL_ARGUMENTS_BYTES=65536
MAX_TOOL_RESULT_BYTES=524288
MAX_JSON_DEPTH=20
MAX_STRING_LENGTH=51200
REDACTION_ENABLED=true
REDACTION_REPLACEMENT=[REDACTED]
REDACTION_FINGERPRINTS_ENABLED=true
REDACTION_FINGERPRINT_KEY=development-only-redaction-key-change-me
MAX_REDACTION_DEPTH=20
MAX_REDACTION_NODES=10000
STORE_REDACTED_ARGUMENTS=true
STORE_REDACTED_RESULTS=true
OTEL_ENABLED=true
OTEL_SERVICE_NAME=toolwatch
OTEL_SERVICE_VERSION=0.1.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=prometheus
OTEL_TRACE_SAMPLE_RATIO=1.0
OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental
METRICS_ENABLED=true
METRICS_PATH=/metrics
DASHBOARD_ENABLED=true
DASHBOARD_PREFIX=/ui
DASHBOARD_PAGE_SIZE=25
DASHBOARD_MAX_PAGE_SIZE=100
DASHBOARD_REFRESH_SECONDS=10
ATTACK_LAB_ENABLED=true
JAEGER_UI_PUBLIC_URL=http://localhost:16686
AGENT_PROVIDER=fake
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_ALLOWED_MODELS=qwen3:4b
FAKE_AGENT_MODEL=fake-v1
FAKE_AGENT_ALLOWED_MODELS=fake-v1
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_KEEP_ALIVE=10m
OLLAMA_THINK=false
AGENT_MAX_TURNS=8
AGENT_MAX_TOOL_CALLS=16
AGENT_MAX_TOOLS_PER_TURN=4
AGENT_MAX_EXPOSED_TOOLS=64
AGENT_MAX_MESSAGE_BYTES=65536
AGENT_MAX_CONVERSATION_BYTES=262144
AGENT_MAX_PROVIDER_RESPONSE_BYTES=1048576
AGENT_RUN_TIMEOUT_SECONDS=180
AGENT_STORE_FINAL_ANSWER=true
RECOVERY_ENABLED=true
TOOL_CALL_STALE_AFTER_SECONDS=300
AGENT_RUN_STALE_AFTER_SECONDS=300
MODEL_CALL_STALE_AFTER_SECONDS=180
RECOVERY_BATCH_SIZE=100
SHUTDOWN_GRACE_PERIOD_SECONDS=15
DOCS_ENABLED=true
TRUSTED_HOSTS=localhost,127.0.0.1,test,api,attack-lab
MAX_HTTP_REQUEST_BYTES=1048576
